{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "photopea",
  "compatibility_date": "2026-07-13",
  "observability": {
    "enabled": true
  },
  "assets": {
    "directory": ".",
    "exclude": [".git/**", ".gitignore", "node_modules/**"]
  },
  "compatibility_flags": [
    "nodejs_compat"
  ]
}
